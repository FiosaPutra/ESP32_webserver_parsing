#include <WiFi.h>
#include <WebServer.h>
#include "DHT.h"

const char* ssid = "YOUR_WIFI_SSID";
const char* password = "YOUR_WIFI_PASSWORD";

#define TCP_PORT 4080
#define LED1_PIN  18
#define LED2_PIN  2
#define DHTPIN 32 
#define DHTTYPE DHT22 

// Variabel Global
int ledState1 = 0;
int ledState2 = 0;
float temperature = 0;
float humidity = 0;

DHT dht(DHTPIN, DHTTYPE);
WiFiServer tcpServer(TCP_PORT);
WebServer webServer(80);

// ===== WEB ROOT (Tampilan di Browser) =====
void handleRoot() {
  String html = "<html><head><meta http-equiv='refresh' content='5'></head><body>"; // Auto refresh 5 detik
  html += "<h1>ESP32 SENSOR & LED</h1>";
  
  html += "<p>Temperature: " + String(temperature, 1) + " C</p>";
  html += "<p>Humidity: " + String(humidity, 1) + " %</p>";

  html += "<h3>LED 1: " + String(ledState1 ? "ON" : "OFF") + "</h3>";
  html += "<a href='/led?id=1&state=1'><button>ON</button></a>";
  html += "<a href='/led?id=1&state=0'><button>OFF</button></a>";

  html += "<h3>LED 2: " + String(ledState2 ? "ON" : "OFF") + "</h3>";
  html += "<a href='/led?id=2&state=1'><button>ON</button></a>";
  html += "<a href='/led?id=2&state=0'><button>OFF</button></a>";
  
  html += "</body></html>";
  webServer.send(200, "text/html", html);
}

// ===== KONTROL LED =====
void handleLed() {
  if (webServer.hasArg("id") && webServer.hasArg("state")) {
    int id = webServer.arg("id").toInt();
    int state = webServer.arg("state").toInt();

    if (id == 1) {
      ledState1 = state;
      digitalWrite(LED1_PIN, state);
    } else if (id == 2) {
      ledState2 = state;
      digitalWrite(LED2_PIN, state);
    }
  }
  // Redirect kembali ke halaman utama
  webServer.sendHeader("Location", "/");
  webServer.send(303);
}

void setup() {
  Serial.begin(115200);
  dht.begin();
  
  pinMode(LED1_PIN, OUTPUT);
  pinMode(LED2_PIN, OUTPUT);
  digitalWrite(LED1_PIN, LOW);
  digitalWrite(LED2_PIN, LOW);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  tcpServer.begin();
  webServer.on("/", handleRoot);
  webServer.on("/led", handleLed);
  webServer.begin();
}

void loop() {
  // Update bacaan sensor ke variabel global
  float h = dht.readHumidity();
  float t = dht.readTemperature();

  if (!isnan(h) && !isnan(t)) {
    humidity = h;
    temperature = t;
  }

  // Cek data masuk via TCP (jika ada kiriman dari device lain)
  WiFiClient client = tcpServer.available();
  if (client && client.available()) {
    String data = client.readStringUntil('\n');
    // Jika format data "TEMP=25,HUM=60"
    int tIdx = data.indexOf("TEMP=");
    int hIdx = data.indexOf("HUM=");
    if (tIdx >= 0 && hIdx >= 0) {
      temperature = data.substring(tIdx + 5, data.indexOf(",", tIdx)).toFloat();
      humidity = data.substring(hIdx + 4).toFloat();
    }
  }

  webServer.handleClient();
}
